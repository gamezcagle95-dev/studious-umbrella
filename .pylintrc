[MASTER]
ignore=venv,node_modules

[MESSAGES CONTROL]
# Disable import-error as dependencies are environment-specific
# Disable numeric R0913/R0917 for deployment function signatures
# Disable W0012 to prevent failures when rules are not recognized by older Pylint versions
disable=
    E0401,
    R0913,
    R0917,
    W0012

[FORMAT]
max-line-length=120

[REPORTS]
fail-under=10.0
